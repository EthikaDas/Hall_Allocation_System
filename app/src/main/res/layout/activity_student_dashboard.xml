<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/dashboard_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/cardProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#22FFFFFF"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="20dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivStudentPhoto"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    app:shapeAppearanceOverlay="@style/CircleImage"
                    app:strokeColor="#4DFFFFFF"
                    app:strokeWidth="2dp"
                    tools:src="@drawable/cat_bg" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/glass_card"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="12dp">
                    <TextView style="@style/LabelStyle" android:text="@string/student_name" />
                    <TextView
                        android:id="@+id/tvStudentName"
                        style="@style/ValueStyle"
                        android:textSize="20sp"
                        tools:text="[Fetching Name...]" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <GridLayout
            android:id="@+id/infoGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toBottomOf="@id/cardProfile">

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/roll" />
                <TextView android:id="@+id/tvRoll" style="@style/ValueStyle" tools:text="[Roll No]" />
            </LinearLayout>

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/dash_series" />
                <TextView android:id="@+id/tvSeries" style="@style/ValueStyle" tools:text="[Series]" />
            </LinearLayout>

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/dash_department" />
                <TextView android:id="@+id/tvDept" style="@style/ValueStyle" tools:text="[Dept]" />
            </LinearLayout>

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/dash_gender" />
                <TextView android:id="@+id/tvGender" style="@style/ValueStyle" tools:text="[Gender]" />
            </LinearLayout>

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/dash_phone" />
                <TextView android:id="@+id/tvPhone" style="@style/ValueStyle" android:textSize="14sp" tools:text="[Phone]" />
            </LinearLayout>

            <LinearLayout style="@style/GlassCardStyle">
                <TextView style="@style/LabelStyle" android:text="@string/dash_email" />
                <TextView android:id="@+id/tvEmail" style="@style/ValueStyle" android:textSize="11sp" tools:text="[Email]" />
            </LinearLayout>

        </GridLayout>

        <TextView
            android:id="@+id/tvOptionsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/hall_services"
            android:textColor="#FAFAFA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            app:layout_constraintTop_toBottomOf="@id/infoGrid"
            app:layout_constraintStart_toStartOf="parent" />

        <GridLayout
            android:id="@+id/optionsGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:columnCount="2"
            android:useDefaultMargins="true"
            app:layout_constraintTop_toBottomOf="@id/tvOptionsTitle">

            <LinearLayout
                android:id="@+id/btnHallApp"
                style="@style/OptionCardStyle">
                <ImageView style="@style/IconStyle" android:src="@android:drawable/ic_menu_edit" />
                <TextView style="@style/OptionTextStyle" android:text="@string/hall_napplication" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnNotifications"
                style="@style/OptionCardStyle">
                <ImageView style="@style/IconStyle" android:src="@android:drawable/ic_popup_reminder" />
                <TextView style="@style/OptionTextStyle" android:text="@string/latest_notifications" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnFindPerson"
                style="@style/OptionCardStyle">
                <ImageView style="@style/IconStyle" android:src="@android:drawable/ic_menu_search" />
                <TextView style="@style/OptionTextStyle" android:text="@string/find_resident_studenT" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnComplaint"
                style="@style/OptionCardStyle">
                <ImageView style="@style/IconStyle" android:src="@android:drawable/ic_menu_report_image" />
                <TextView style="@style/OptionTextStyle" android:text="@string/file_a_complaint" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnExit"
                style="@style/OptionCardStyle"
                android:layout_columnSpan="2"
                android:layout_gravity="center_horizontal"
                android:layout_width="160dp"
                android:minHeight="45dp"
                android:layout_marginTop="8dp">

                <ImageView
                    style="@style/IconStyle"
                    android:src="@android:drawable/ic_menu_revert"
                    android:layout_width="18dp"
                    android:layout_height="18dp"/>

                <TextView
                    style="@style/OptionTextStyle"
                    android:text="@string/exit"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

        </GridLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.core.widget.NestedScrollView>